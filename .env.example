# 必填：DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 可选：DeepSeek 接口/模型
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 可选：海外补充抓取（Serper）
SERPER_API_KEY=

# 可选：性能/调试
DEBUG=false
CFC_FAST_MODE=false
DOMESTIC_SUMMARY_LIMIT=36
OVERSEAS_SUMMARY_LIMIT=60
SUMMARY_BATCH_SIZE=5
SELECTED_REFINE_LIMIT=14
SERPER_QUERY_LIMIT=18
SERPER_RESULT_LIMIT=8
